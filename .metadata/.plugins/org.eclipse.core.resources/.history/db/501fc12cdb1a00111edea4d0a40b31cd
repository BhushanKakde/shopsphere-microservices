<%@ page contentType="text/html;charset=UTF-8" %>
<!DOCTYPE html>
<html>
<head>
<title>ShopSphere | Home</title>

<style>
body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #f1f3f6;
}

.header {
    background: #2874f0;
    color: white;
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-size: 24px;
    font-weight: bold;
}

.user-info {
    display: flex;
    align-items: center;
    gap: 15px;
}

.logout-btn {
    background: white;
    color: #2874f0;
    border: none;
    padding: 8px 14px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
}

.cart-link {
    background: #ff9f00;
    color: white;
    padding: 8px 14px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: bold;
}

/* NEW ORDER BUTTON */

.orders-link{
    background:#00a65a;
    color:white;
    padding:8px 14px;
    border-radius:4px;
    text-decoration:none;
    font-weight:bold;
}

.orders-link:hover{
    background:#008d4c;
}

.welcome {
    padding: 20px 30px;
    background: white;
}

.welcome h2 {
    color: #2874f0;
    margin-bottom: 5px;
}

.container {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    padding: 30px;
}

.card {
    background: white;
    width: 220px;
    padding: 12px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    transition: transform 0.2s;
}

.card:hover {
    transform: scale(1.03);
}

.card img {
    width: 100%;
    height: 150px;
    object-fit: cover;
}

.price {
    color: green;
    font-weight: bold;
    margin: 5px 0;
}

.cart-btn {
    width: 100%;
    background: #fb641b;
    color: white;
    border: none;
    padding: 8px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
}

.cart-btn:hover {
    background: #e65c00;
}

.card h4 {
    color: #212121;
    margin: 8px 0 4px;
}

.card p {
    color: #555;
    font-size: 14px;
    margin: 4px 0;
}
</style>
</head>

<body>

<!-- HEADER -->
<div class="header">
    <div class="logo">🛒 ShopSphere</div>

    <div class="user-info">
        <span id="usernameText">Hello 👋</span>

        <!-- NEW BUTTON -->
        <a href="/orders" class="orders-link">📦 My Orders</a>

        <a href="/cart" class="cart-link">🛒 Cart</a>

        <form action="/logout" method="get">
            <button class="logout-btn">Logout</button>
        </form>
    </div>
</div>

<!-- WELCOME -->
<div class="welcome">
    <h2>Welcome to ShopSphere 🎉</h2>
    <p>Explore amazing products and best deals just for you.</p>
</div>

<!-- PRODUCTS -->
<div class="container" id="productContainer"></div>

<script>

// SESSION DATA
const username = "<%= session.getAttribute("username") %>";
const userId = "<%= session.getAttribute("userId") %>";

if (username && username !== "null") {
    document.getElementById("usernameText").innerText =
        "Hello, " + username + " 👋";
}

// LOAD PRODUCTS
fetch("http://localhost:8080/products")
.then(res => res.json())
.then(data => {

    const container = document.getElementById("productContainer");
    container.innerHTML = "";

    if (!data || data.length === 0) {
        container.innerHTML = "<p>No products available</p>";
        return;
    }

    data.forEach(p => {
        container.innerHTML += `
            <div class="card">
                <img src="${p.imageUrl}"
                     onerror="this.src='https://via.placeholder.com/200?text=No+Image'">
                <h4>${p.name}</h4>
                <p>${p.description}</p>
                <p class="price">₹${p.price}</p>
                <button class="cart-btn"
                    onclick="addToCart(${p.id})">
                    Add to Cart
                </button>
            </div>
        `;
    });

})
.catch(() => {
    document.getElementById("productContainer")
        .innerHTML = "<p>❌ Failed to load products</p>";
});

// ADD TO CART
function addToCart(productId) {

    if (!userId || userId === "null") {
        alert("Please login again");
        return;
    }

    fetch("http://localhost:8083/cart/add", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
            userId: userId,
            productId: productId,
            quantity: 1
        })
    })
    .then(res => {
        if (!res.ok) throw new Error();
        alert("✅ Product added to cart");
    })
    .catch(() => alert("❌ Error adding to cart"));
}

</script>

</body>
</html>